# =============================================================================
#  AlgoTrade Pro — Environment Configuration
# =============================================================================
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
#  Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
#  Trading Mode
# -----------------------------------------------------------------------------
# paper  — simulated execution, zero real orders (DEFAULT, RECOMMENDED)
# live   — real orders on WEEX Futures (requires explicit opt-in)
TRADING_MODE=paper
PAPER_STARTING_BALANCE=10000
# If true, all open positions will be closed via MARKET orders on SIGTERM/SIGINT
SHUTDOWN_LIQUIDATE_POSITIONS=false

# -----------------------------------------------------------------------------
#  WEEX Futures API
#  How to get: https://www.weex.com/apiManagement  →  Create API Key → enable Futures
# -----------------------------------------------------------------------------
WEEX_API_KEY=
WEEX_SECRET_KEY=
WEEX_PASSPHRASE=
WEEX_REST_URL=https://api.weex.com
WEEX_WS_URL=wss://api.weex.com/v2/ws/public
WEEX_WS_PRIVATE_URL=wss://api.weex.com/v2/ws/private

# -----------------------------------------------------------------------------
#  Trading Symbols (comma-separated, no spaces)
#  WEEX futures format uses _UMCBL suffix for USDT-M perpetuals
# -----------------------------------------------------------------------------
SYMBOLS=XAUTUSDT,BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT
TIMEFRAMES=10m,1h,1D
DEFAULT_LEVERAGE=5

# -----------------------------------------------------------------------------
#  Risk Management
# -----------------------------------------------------------------------------
MAX_POSITION_SIZE_PERCENT=5
MAX_DAILY_LOSS_PERCENT=3
MAX_CONCURRENT_POSITIONS=3
CORRELATION_VETO_THRESHOLD=0.75
# Correlation penalty halves size of each subsequent cluster position.
# Keep DISABLED while using fixed-$10 test notional — otherwise size drops below exchange min.
# Enable when moving to real % -of-balance sizing.
CORRELATION_PENALTY_ENABLED=false
# Fixed USDT notional per position (test mode). Will be replaced by balance*risk% in prod.
TEST_FIXED_NOTIONAL_USD=10
# Reject orders below this notional (exchange will reject with MIN_NOTIONAL otherwise).
EXCHANGE_MIN_NOTIONAL_USD=5
DEFAULT_SL_ATR_MULT=2.0
DEFAULT_TP1_ATR_MULT=1.5
DEFAULT_TP2_ATR_MULT=3.0
DEFAULT_TP3_ATR_MULT=5.0

# -----------------------------------------------------------------------------
#  AI Arbiter (OpenRouter)
#  How to get: https://openrouter.ai/keys
#  Models: anthropic/claude-sonnet-4, openai/gpt-4o, google/gemini-pro-1.5
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ARBITER_MODE=FULL
ARBITER_LLM_TIMEOUT_MS=15000
ARBITER_CACHE_TTL_SECONDS=10

# -----------------------------------------------------------------------------
#  TradingView Webhook
#  Use ngrok/cloudflare-tunnel to expose localhost publicly
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=change_me_to_a_long_random_string
WEBHOOK_HMAC_SECRET=change_me_too_for_signature_validation
# When true (or NODE_ENV=production), webhook requires x-timestamp + x-signature headers.
# Signature = hex(hmac-sha256(`${unixSeconds}.${rawBody}`, WEBHOOK_HMAC_SECRET))
WEBHOOK_HMAC_REQUIRED=false
WEBHOOK_REPLAY_WINDOW_SECONDS=300
WEBHOOK_IDEMPOTENCY_TTL_SECONDS=300
WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
#  Telegram Bot
#  How to get:
#    1. Create bot via @BotFather → get token
#    2. Start chat with bot, then visit:
#       https://api.telegram.org/bot<TOKEN>/getUpdates  → copy chat.id
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
#  Multi-User Platform
#  Generate MASTER_ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
MASTER_ENCRYPTION_KEY=
MINI_APP_URL=

# -----------------------------------------------------------------------------
#  External Data Providers (optional)
# -----------------------------------------------------------------------------
TWELVEDATA_API_KEY=
FEAR_GREED_API_URL=https://api.alternative.me/fng/

# -----------------------------------------------------------------------------
#  Observability
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PATH=/metrics
