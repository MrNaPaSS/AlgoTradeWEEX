  "description": "Enterprise AI-Powered Futures Trading System (WEEX) — multi-agent consilium with LLM arbiter, Black Mirror Ultra indicator, paper/live trading modes",
  "main": "src/app.js",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
