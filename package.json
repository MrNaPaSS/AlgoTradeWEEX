  "license": "MIT",
  "dependencies": {
    "async-mutex": "^0.5.0",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "json-bigint": "^1.0.0",
    "nanoid": "^3.3.7",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.73.0",
    "opossum": "^8.2.2",
    "p-queue": "^6.6.2",
    "p-retry": "^4.6.2",
    "prom-client": "^15.1.3",
    "sql.js": "^1.12.0",
